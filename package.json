{
	"name": "@llm/agent",
	"version": "0.1.0",
	"description": "LLM-agnostic AI agent library with generic provider interface, retry logic, and built-in Gemini support",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"license": "MIT",
	"keywords": [
		"llm",
		"gemini",
		"ai",
		"agent",
		"provider",
		"openai",
		"anthropic"
	]
}
